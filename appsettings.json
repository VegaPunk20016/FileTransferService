{
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/fts-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "TransferSettings": {
    "Transfers": [
      {
        "Name": "FileGeneratorToMFT",
        "SourcePath": "C:\\FileGenerator\\Outbound",
        "DestinationPath": "C:\\MFT\\Inbound",
        "Strategy": "RemoveIntermediateFolder",
        "IncludeSubdirectories": true,
        "MaxConcurrentTransfers": 5,
        "FileValidationTimeoutSeconds": 2
      },
      {
        "Name": "MFTOutboundExport",
        "SourcePath": "C:\\MFT\\Outbound",
        "DestinationPath": "C:\\MFT\\Inbound",
        "Strategy": "PreserveRelativeStructure",
        "IncludeSubdirectories": true,
        "MaxConcurrentTransfers": 3,
        "FileValidationTimeoutSeconds": 2
      }
    ]
  }
}
